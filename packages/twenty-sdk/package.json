{
  "name": "twenty-sdk",
  "version": "0.0.0-dev",
  "private": false,
  "description": "CLI for Twenty CRM",
  "license": "MIT",
  "bin": {
    "twenty": "dist/cli/cli.js"
  },
  "files": [
    "dist/**/*"
  ],
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/cli && cp src/cli/help.txt dist/cli/help.txt",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts",
    "test:e2e": "pnpm run build && vitest run -c vitest.e2e.config.ts"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "axios-retry": "^4.1.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "form-data": "^4.0.5",
    "fs-extra": "^11.2.0",
    "jmespath": "^0.16.0",
    "papaparse": "^5.4.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jmespath": "^0.15.2",
    "@types/node": "^25.3.0",
    "@types/papaparse": "^5.3.14",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "dist/cli/help.txt"
    ]
  }
}
